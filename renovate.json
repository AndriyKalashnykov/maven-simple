{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "enabledManagers": [
    "maven",
    "github-actions",
    "custom.regex"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "JAVA_VER\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "java",
      "datasourceTemplate": "adoptium-java"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "ACT_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "nektos/act",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Label Java dependencies",
      "matchCategories": [
        "java"
      ],
      "addLabels": [
        "lang: java"
      ]
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group Jackson dependencies",
      "groupName": "Jackson",
      "matchPackageNames": [
        "/^com\\.fasterxml\\.jackson/"
      ]
    },
    {
      "description": "Group OkHttp dependencies",
      "groupName": "OkHttp",
      "matchPackageNames": [
        "/^com\\.squareup\\.okhttp3/"
      ]
    },
    {
      "description": "Group Retrofit dependencies",
      "groupName": "Retrofit",
      "matchPackageNames": [
        "/^com\\.squareup\\.retrofit2/"
      ]
    },
    {
      "description": "Group SLF4J dependencies",
      "groupName": "SLF4J",
      "matchPackageNames": [
        "/^org\\.slf4j/"
      ]
    }
  ]
}
