{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "enabledManagers": [
    "maven",
    "github-actions",
    "custom.regex"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "branch",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track Java version in Makefile",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "JAVA_VER\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "java",
      "datasourceTemplate": "adoptium-java",
      "extractVersionTemplate": "^(?<version>\\d+)"
    },
    {
      "customType": "regex",
      "description": "Track act version in Makefile",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "ACT_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "nektos/act",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track Maven version in Makefile",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "MAVEN_VER\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "org.apache.maven:apache-maven",
      "datasourceTemplate": "maven"
    },
    {
      "customType": "regex",
      "description": "Track nvm version in Makefile",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "NVM_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "nvm-sh/nvm",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track Renovate version in Makefile",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "RENOVATE_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "renovatebot/renovate",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track Node.js version in Makefile",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "NODE_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version"
    }
  ],
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Label Java dependencies",
      "matchCategories": [
        "java"
      ],
      "addLabels": [
        "lang: java"
      ]
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group Makefile tool versions into one PR",
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "Makefile tool versions"
    },
    {
      "description": "Group Jackson 3.x dependencies",
      "groupName": "Jackson",
      "matchPackageNames": [
        "/^tools\\.jackson/",
        "/^com\\.fasterxml\\.jackson\\.annotation/"
      ]
    },
    {
      "description": "Group OkHttp dependencies (including KMP -jvm artifacts)",
      "groupName": "OkHttp",
      "matchPackageNames": [
        "/^com\\.squareup\\.okhttp3/"
      ]
    },
    {
      "description": "Group Retrofit dependencies",
      "groupName": "Retrofit",
      "matchPackageNames": [
        "/^com\\.squareup\\.retrofit2/"
      ]
    },
    {
      "description": "Group SLF4J dependencies",
      "groupName": "SLF4J",
      "matchPackageNames": [
        "/^org\\.slf4j/"
      ]
    },
    {
      "description": "Group Apache Commons dependencies",
      "groupName": "Apache Commons",
      "matchPackageNames": [
        "/^org\\.apache\\.commons/",
        "/^commons-/"
      ]
    },
    {
      "description": "Group testing dependencies",
      "groupName": "Testing",
      "matchPackageNames": [
        "/^org\\.junit/",
        "/^org\\.mockito/"
      ]
    },
    {
      "description": "Group Maven plugin dependencies",
      "groupName": "Maven Plugins",
      "matchPackageNames": [
        "/^org\\.apache\\.maven\\.plugins/",
        "/^org\\.codehaus\\.mojo/"
      ]
    }
  ]
}
